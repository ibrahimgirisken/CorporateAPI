@model CreateBannerDTO
@{
    ViewData["Title"] = "Yeni Banner Ekleme Sayfası";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="container-fluid my-5">
<form method="post" class="form-group">
    <div class="form-group">
        <label>Resim1</label>
        <input type="text" name="DesktopImage" class="form-control" />
    </div>
    <div class="form-group">
        <label>Resim2</label>
        <input type="text" name="TableteImage" class="form-control" />
    </div>
    <div class="form-group">
        <label>Resim3</label>
        <input type="text" name="MobileImage" class="form-control" />
    </div>

    <ul class="nav nav-tabs" id="myTab" role="tablist">
        @foreach (var lang in Model.BannerTranslations)
        {
            <li class="nav-item" role="presentation">
                <button class="nav-link @(lang.Locale == "tr" ? "active" : "")" id="@lang.Locale-tab" data-bs-toggle="tab" data-bs-target="#@lang.Locale" type="button" role="tab" aria-controls="@lang.Locale" aria-selected="@(lang.Locale == "tr" ? "true" : "false")">
                    <img width="15" height="15" src="~/icons/@(lang.Locale).svg" />@lang.Locale
                </button>
            </li>
        }
    </ul>

    <div class="tab-content mt-3" id="myTabContent">
        @for (int i = 0; i < Model.BannerTranslations.Count; i++)
        {
            var lang = Model.BannerTranslations.ToList()[i];
            <div class="tab-pane fade show @(lang.Locale == "tr" ? "active" : "")" id="@lang.Locale" role="tabpanel" aria-labelledby="@lang.Locale-tab">
                <div class="card-body">
                    <input type="hidden" name="Translations[@i].Locale" value="@lang.Locale" />
                    <div class="form-group">
                        <label for="Url">Url</label>
                        <input type="text" name="Translations[@i].Url" class="form-control" value="@lang.Url" />
                    </div>
                    <div class="form-group">
                        <label for="Title">Başlık</label>
                        <input type="text" name="Translations[@i].Title" class="form-control" value="@lang.Title" />
                    </div>
                    <div class="form-group">
                        <label for="Content">Açıklama</label>
                        <textarea class="form-control" name="Translations[@i].Content">@lang.Content</textarea>
                    </div>
                </div>
            </div>
        }
    </div>
    <div class="form-group">
        <label>Sıra</label>
        <input type="number" name="Order" class="form-control" />
    </div>
    <input type="submit" value="Verileri Gönder" />

</form>
</div>