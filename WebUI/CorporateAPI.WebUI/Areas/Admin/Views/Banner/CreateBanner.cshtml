@model CreateBannerViewModel
@{
    ViewData["Title"] = "Yeni Banner Ekleme Sayfası";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<form asp-action="CreateBanner" method="post">
    <!-- Desktop, Tablet ve Mobil Görseller -->
    <div class="form-group">
        <label asp-for="CreateBannerDTO.DesktopImage">Masaüstü Görsel</label>
        <input type="text" class="form-control" asp-for="CreateBannerDTO.DesktopImage" placeholder="Masaüstü Görsel">
    </div>

    <div class="form-group">
        <label asp-for="CreateBannerDTO.TableteImage">Tablet Görsel</label>
        <input type="text" class="form-control" asp-for="CreateBannerDTO.TableteImage" placeholder="Tablet Görsel">
    </div>

    <div class="form-group">
        <label asp-for="CreateBannerDTO.MobileImage">Mobil Görsel</label>
        <input type="text" class="form-control" asp-for="CreateBannerDTO.MobileImage" placeholder="Mobil Görsel">
    </div>

    <!-- Nav Tab: Çeviriler (BannerTranslations) -->
    <ul class="nav nav-tabs" id="translation-tab" role="tablist">
        @for (int i = 0; i < Model.BannerTranslations.Count; i++)
        {
            var locale = Model.BannerTranslations[i].Locale;
            <li class="nav-item">
                <a class="nav-link @(i == 0 ? "active" : "")" id="tab-@locale" data-bs-toggle="pill" href="#content-@locale" role="tab" aria-controls="content-@locale" aria-selected="@(i == 0)">
                    @locale.ToUpper()
                </a>
            </li>
        }
    </ul>

    <div class="tab-content" id="translation-tabContent">
        @for (int i = 0; i < Model.BannerTranslations.Count; i++)
        {
            var locale = Model.BannerTranslations[i].Locale;
            <div class="tab-pane fade @(i == 0 ? "show active" : "")" id="content-@locale" role="tabpanel" aria-labelledby="tab-@locale">
                <div class="form-group">
                    <label asp-for="@($"BannerTranslations[{i}].Locale")">Dil (@locale.ToUpper())</label>
                    <input type="text" class="form-control" asp-for="@($"BannerTranslations[{i}].Locale")" readonly>
                </div>
                <div class="form-group">
                    <label asp-for="@($"BannerTranslations[{i}].Url")">URL (@locale.ToUpper())</label>
                    <input type="text" class="form-control" asp-for="@($"BannerTranslations[{i}].Url")">
                </div>
                <div class="form-group">
                    <label asp-for="@($"BannerTranslations[{i}].Title")">Başlık (@locale.ToUpper())</label>
                    <input type="text" class="form-control" asp-for="@($"BannerTranslations[{i}].Title")">
                </div>
                <div class="form-group">
                    <label asp-for="@($"BannerTranslations[{i}].Content")">İçerik (@locale.ToUpper())</label>
                    <textarea class="form-control" asp-for="@($"BannerTranslations[{i}].Content")"></textarea>
                </div>
            </div>
        }
    </div>

    <!-- Sıra ve Durum -->
    <div class="form-group">
        <label asp-for="CreateBannerDTO.Order">Sıra</label>
        <input type="number" class="form-control" asp-for="CreateBannerDTO.Order" placeholder="Sıra">
    </div>

    <div class="form-group">
        <label asp-for="CreateBannerDTO.IsDeleted">Durum</label>
        <input type="checkbox" class="form-check-input" asp-for="CreateBannerDTO.IsDeleted">
    </div>

    <!-- Submit Button -->
    <button type="submit" class="btn btn-primary">Kaydet</button>
</form>