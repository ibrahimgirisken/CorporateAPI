@model List<ResultBannerDTO>
@{
    ViewData["Title"] = "Banner Sayfası";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<table class="table table-hover">
    <tr>
        <th>#</th>
        <th>Görsel</th>
        <th>Başlık</th>
        <th>Sıra</th>
        <th>İşlemler</th>
    </tr>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td><img src="@item.DesktopImage" style="height:75px;width:75px" /></td>
            <td>@item.BannerTranslations.FirstOrDefault(t => t.Locale == "tr")?.Title ?? "Başlık Yok"</td>
            <td>@item.Order</td>
            <td>
                <a asp-action="DeleteBanner" asp-controller="Banner" asp-route-id="@item.Id" class="btn btn-outline-danger">Sil</a>
                <a asp-action="UpdateBanner" asp-controller="Banner" asp-route-id="@item.Id" class="btn btn-outline-info">Güncelle</a>
            </td>
        </tr>
    }
</table>
<br />
<a asp-action="CreateBanner" asp-controller="Banner" asp-area="Admin" class="btn btn-outline-primary">Yeni Banner Ekle</a>

