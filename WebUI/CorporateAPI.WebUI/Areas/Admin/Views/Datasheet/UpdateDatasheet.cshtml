@model UpdateDatasheetViewModel
@{
    ViewData["Title"] = "Datasheet Güncelleme";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid my-5">
    <form method="post" asp-action="UpdateDatasheet" enctype="multipart/form-data">
        <input type="hidden" asp-for="UpdateDatasheetDTO.Id" />
        <div class="form-group">
            <label asp-for="UpdateDatasheetDTO.Code"></label>
            <input asp-for="UpdateDatasheetDTO.Code" class="form-control" />
        </div>
        <ul class="nav nav-tabs" id="myTab" role="tablist">
            @for (int i = 0; i < Model.GetLangDTOs.Count; i++)
            {
                var lang = Model.GetLangDTOs[i];
                <li class="nav-item" role="presentation">
                    <button class="nav-link @(lang.LangCode == "tr" ? "active" : "")" id="@lang.LangCode-tab" data-bs-toggle="tab" data-bs-target="#@lang.LangCode" type="button" role="tab" aria-controls="@lang.LangCode" aria-selected="@(lang.LangCode == "tr" ? "true" : "false")">
                        <img width="15" height="15" src="~/icons/@(lang.LangCode).svg" />@lang.LangCode
                    </button>
                </li>
            }
        </ul>
        <div class="tab-content mt-3" id="myTabContent">
            @for (int i = 0; i < Model.UpdateDatasheetDTO.DatasheetTranslations.Count; i++)
            {
                var translation = Model.UpdateDatasheetDTO.DatasheetTranslations[i];
                <div class="tab-pane fade show @(translation.Locale == "tr" ? "active" : "")" id="@translation.Locale" role="tabpanel" aria-labelledby="@translation.Locale-tab">
                    <div class="form-group">
                        <input type="hidden" asp-for="UpdateDatasheetDTO.DatasheetTranslations[i].Locale" />
                        <label asp-for="UpdateDatasheetDTO.DatasheetTranslations[i].Name"></label>
                        <input asp-for="UpdateDatasheetDTO.DatasheetTranslations[i].Name" class="form-control" />
                        <label asp-for="UpdateDatasheetDTO.DatasheetTranslations[i].Url"></label>
                        <input asp-for="UpdateDatasheetDTO.DatasheetTranslations[i].Url" class="form-control" />
                        <input type="hidden" asp-for="UpdateDatasheetDTO.DatasheetTranslations[i].Path" class="form-control" />
                        <span class="@(string.IsNullOrEmpty(Model.UpdateDatasheetDTO.DatasheetTranslations[i].Path) ? "text-danger" : "text-success")">
                            @(string.IsNullOrEmpty(Model.UpdateDatasheetDTO.DatasheetTranslations[i].Path) ? "Path bulunamadı" : Model.UpdateDatasheetDTO.DatasheetTranslations[i].Path)
                        </span>
                        <input type="file" asp-for="UpdateDatasheetDTO.DatasheetTranslations[i].DatasheetFile" class="form-control" />
                        <label asp-for="UpdateDatasheetDTO.DatasheetTranslations[i].Content"></label>
                        <input asp-for="UpdateDatasheetDTO.DatasheetTranslations[i].Content" class="form-control" />
                    </div>
                </div>
            }
        </div>
        <div class="form-group">
            <label asp-for="UpdateDatasheetDTO.Image1"></label>
            <input asp-for="UpdateDatasheetDTO.Image1" class="form-control" />
        </div>
        <div class="form-group">
            <label asp-for="UpdateDatasheetDTO.Order"></label>
            <input asp-for="UpdateDatasheetDTO.Order" class="form-control" />
        </div>
        <div class="form-check">
            <label asp-for="UpdateDatasheetDTO.Status" class="form-check-label"></label>
            <input asp-for="UpdateDatasheetDTO.Status" class="form-check-input" type="checkbox" />
        </div>
        <input type="submit" class="btn btn-primary" value="Kaydet" />

    </form>
</div>
