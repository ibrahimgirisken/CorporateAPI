@model CreatePageDTO
@{
    ViewData["Title"] = "Yeni Sayfa Oluşturma";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<div class="container-fluid my-5">
    <form method="post">
        <div class="form-group">
            <label>Moduller</label>
            <select class="form-select" aria-label="Default select example">
                <option selected>Open this select menu</option>
                <option value="1">One</option>
                <option value="2">Two</option>
                <option value="3">Three</option>
            </select>
        </div>
        <div class="form-group">
            <label>Resim1</label>
            <input type="text" asp-for="@Model.Image1" class="form-control" />
        </div>
        <div class="form-group">
            <label>Resim2</label>
            <input type="text" asp-for="@Model.Image2" class="form-control" />
        </div>
        <div class="form-group">
            <label>Resim3</label>
            <input type="text" asp-for="@Model.Image3" class="form-control" />
        </div>
        <ul class="nav nav-tabs" id="myTab" role="tablist">
            @foreach (var lang in Model.Translations)
            {
                <li class="nav-item" role="presentation">
                    <button class="nav-link @(lang.Locale == "tr" ? "active" : "")" id="@lang.Locale-tab" data-bs-toggle="tab" data-bs-target="#@lang.Locale" type="button" role="tab" aria-controls="@lang.Locale" aria-selected="@(lang.Locale == "tr" ? "true" : "false")">
                        <img width="15" height="15" src="~/icons/@(lang.Locale).svg" />@lang.Locale
                    </button>
                </li>
            }
        </ul>

        <div class="tab-content mt-3" id="myTabContent">
            @foreach (var lang in Model.Translations)
            {
                <div class="tab-pane fade show @(lang.Locale == "tr" ? "active" : "")" id="@lang.Locale" role="tabpanel" aria-labelledby="@lang.Locale-tab">
                    <div class="card-body">
                        <div class="form-group">
                            <input type="text" name="Translations[@Model.Translations.ToList().IndexOf(lang)].Locale" value="@lang.Locale" hidden class="form-control" id="exampleInputPassword1" placeholder="Dil">
                        </div>
                        <div class="form-group">
                            <label for="exampleInputPassword1">Başlık</label>
                            <input type="text" name="Translations[@Model.Translations.ToList().IndexOf(lang)].Title" class="form-control" id="exampleInputPassword1" placeholder="Başlık">
                        </div>
                        <div class="form-group">
                            <label for="exampleInputPassword1">Url</label>
                            <input type="text" name="Translations[@Model.Translations.ToList().IndexOf(lang)].Url" class="form-control" id="exampleInputPassword1" placeholder="Sayfa Url">
                        </div>
                        <div class="form-group">
                            <label for="exampleInputPassword1">Sayfa Başlık</label>
                            <input type="text" name="Translations[@Model.Translations.ToList().IndexOf(lang)].PageTitle" class="form-control" id="exampleInputPassword1" placeholder="Sayfa Başlık">
                        </div>
                        <div class="form-group">
                            <label for="exampleInputPassword1">Kısa Açıklama</label>
                            <input type="text" name="Translations[@Model.Translations.ToList().IndexOf(lang)].Brief" class="form-control" id="exampleInputPassword1" placeholder="Kısa Açıklama">
                        </div>
                        <div class="form-group">
                            <label for="exampleInputPassword1">Meta Açıklama</label>
                            <input type="text" name="Translations[@Model.Translations.ToList().IndexOf(lang)].MetaDescription" class="form-control" id="exampleInputPassword1" placeholder="Meta Açıklama">
                        </div>
                        <div class="form-group">
                            <label for="floatingTextarea1">Açıklama</label>
                            <textarea class="form-control" name="Translations[@Model.Translations.ToList().IndexOf(lang)].MetaDescription" placeholder="Açıklama" id="floatingTextarea1"></textarea>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="form-group">
            <label>Sıra</label>
            <input type="number" asp-for="@Model.Order" class="form-control" placeholder="Sıra" />
        </div>
            <button class="btn btn-outline-primary">Kaydet</button>
    </form>

</div>