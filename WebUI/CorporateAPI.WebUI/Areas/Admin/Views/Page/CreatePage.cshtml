@model CreatePageViewModel
@{
    ViewData["Title"] = "Yeni Sayfa Oluşturma";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<div class="container-fluid my-5">
<form method="post">
    <div class="form-group">
            <label>Menuler</label>
            <select class="form-select" aria-label="Module">
                <option selected>select</option>
                @foreach (var item in Model.GetModuleDTOs.ModuleTranslations)
                {
                    <option selected>@item.Name</option>
                }
            </select>
    </div>
        <div class="form-group">
            <label>Moduller</label>
            <select class="form-select" aria-label="Default select example">
                <option selected>Open this select menu</option>
                <option value="1">One</option>
                <option value="2">Two</option>
                <option value="3">Three</option>
            </select>
        </div>
    <ul class="nav nav-tabs" id="myTab" role="tablist">
        <li class="nav-item" role="presentation">
                <button class="nav-link active" id="home-tab" data-bs-toggle="tab" data-bs-target="#home" type="button" role="tab" aria-controls="home" aria-selected="true"><img width="15" height:"15" src="~/icons/tr.svg" />Türkçe</button>
        </li>
        <li class="nav-item" role="presentation">
                <button class="nav-link" id="profile-tab" data-bs-toggle="tab" data-bs-target="#profile" type="button" role="tab" aria-controls="profile" aria-selected="false"><img width="15" height:"15" src="~/icons/en.svg" />English</button>
        </li>
        <li class="nav-item" role="presentation">
                <button class="nav-link" id="contact-tab" data-bs-toggle="tab" data-bs-target="#contact" type="button" role="tab" aria-controls="contact" aria-selected="false"><img width="15" height:"15" src="~/icons/de.svg" />Deutche</button>
        </li>
    </ul>

    <div class="tab-content mt-3" id="myTabContent">

        <div class="tab-pane fade show active" id="home" role="tabpanel" aria-labelledby="home-tab">
            <div class="card-body">
                <div class="form-group">
                    <label for="exampleInputPassword1">Başlık</label>
                    <input type="text" name="trTitle" class="form-control" id="exampleInputPassword1" placeholder="Başlık">
                </div>
                <div class="form-group">
                    <label for="exampleInputPassword1">SEO Sayfa Url</label>
                    <input type="text" name="trUrl" class="form-control" id="exampleInputPassword1" placeholder="SEO Sayfa Url">
                </div>
                <div class="form-group">
                    <label for="exampleInputPassword1">Sayfa İçi Başlık</label>
                    <input type="text" name="trPageTitle" class="form-control" id="exampleInputPassword1" placeholder="Sayfa İçi Başlık">
                </div>
                <div class="form-group">
                    <label for="exampleInputPassword1">Kısa Açıklama</label>
                    <input type="text" name="trBrief" class="form-control" id="exampleInputPassword1" placeholder="Kısa Açıklama">
                </div>
                <div class="form-group">
                    <label for="exampleInputPassword1">Keywords</label>
                    <input type="text" name="trKeywords" class="form-control" id="exampleInputPassword1" placeholder="Keywords">
                </div>
                <div class="form-group">
                    <label for="exampleInputPassword1">Description</label>
                    <input type="text" name="trDescription" class="form-control" id="exampleInputPassword1" placeholder="Description">
                </div>
                <div class="form-group">
                    <label for="floatingTextarea1">Açıklama</label>
                    <textarea class="form-control" name="trContent" placeholder="De Açıklama" id="floatingTextarea1"></textarea>
                </div>
            </div>
        </div>
    </div>
    <div class="form-group">
        <label>Order</label>
        <input type="number" asp-for="CreatePageDTO.Order" class="form-control" />
    </div>
    <div class="form-group">
        <button class="btn btn-outline-primary">Kaydet</button>
    </div>
</form>

</div>