@model CreatePageViewModel
@{
    ViewData["Title"] = "Yeni Sayfa Ekleme";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="container-fluid my-5">
    <form method="post" action="CreatePage">
        <div class="form-group">
            <label asp-for="CreatePageDTO.ModuleIds"></label>
            <select class="form-select" asp-for="CreatePageDTO.ModuleIds">
                <option value="0" selected>Seç</option>
                @foreach (var item in Model.GetModuleDTOs)
                {
                    <option value="@item.Id">
                        @item.ContentType
                    </option>
                }
            </select>
        </div>
        <div class="form-group">
            <label asp-for="CreatePageDTO.Image1"></label>
            <input asp-for="CreatePageDTO.Image1" class="form-control" />
        </div>
        <div class="form-group">
            <label asp-for="CreatePageDTO.Image2"></label>
            <input asp-for="CreatePageDTO.Image2" class="form-control" />
        </div>
        <div class="form-group">
            <label asp-for="CreatePageDTO.Image3"></label>
            <input asp-for="CreatePageDTO.Image3" class="form-control" />
        </div>
        <ul class="nav nav-tabs" id="myTab" role="tablist">
            @for (int i = 0; i < Model.GetLangDTOs.Count; i++)
            {
                var lang = Model.GetLangDTOs[i];
                <li class="nav-item" role="presentation">
                    <button class="nav-link @(lang.LangCode == "tr" ? "active" : "")" id="@lang.LangCode-tab" data-bs-toggle="tab" data-bs-target="#@lang.LangCode" type="button" role="tab" aria-controls="@lang.LangCode" aria-selected="@(lang.LangCode == "tr" ? "true" : "false")">
                        <img width="15" height="15" src="~/icons/@(lang.LangCode).svg" />@lang.LangCode
                    </button>
                </li>
            }
        </ul>
        <div class="tab-content mt-3" id="myTabContent">
            @for (int i = 0; i < Model.CreatePageDTO.PageTranslations.Count; i++)
            {
                var lang = Model.CreatePageDTO.PageTranslations.ToList()[i];
                <div class="tab-pane fade show @(lang.Locale == "tr" ? "active" : "")" id="@lang.Locale" role="tabpanel" aria-labelledby="@lang.Locale-tab">
                    <div class="card-body">
                        <input type="hidden" asp-for="PageTranslations[@i].Locale" value="@lang.Locale" />

                        <div class="form-group">
                            <label asp-for="PageTranslations[@i].Title"></label>
                            <input asp-for="PageTranslations[@i].Title" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label asp-for="PageTranslations[@i].Url"></label>
                            <input asp-for="PageTranslations[@i].Url" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label asp-for="PageTranslations[@i].PageTitle"></label>
                            <input asp-for="PageTranslations[@i].PageTitle." class="form-control" />
                        </div>
                        <div class="form-group">
                            <label asp-for="PageTranslations[@i].Brief"></label>
                            <input asp-for="PageTranslations[@i].Brief" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label asp-for="PageTranslations[@i].MetaDescription"></label>
                            <input asp-for="PageTranslations[@i].MetaDescription" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label asp-for="PageTranslations[@i].Content"></label>
                            <textarea asp-for="PageTranslations[@i].Content" class="form-control"></textarea>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="form-group">
            <label asp-for="CreatePageDTO.Order"></label>
            <input t asp-for="CreatePageDTO.Order" class="form-control" value=1 />
        </div>
        <input type="submit" value="Verileri Gönder"/>

    </form>


</div>