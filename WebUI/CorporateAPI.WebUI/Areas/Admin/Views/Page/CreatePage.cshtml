@model CreatePageDTO
@{
    ViewData["Title"] = "Yeni Sayfa Oluşturma";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<div class="container-fluid my-5">
    <form method="post" asp-controller="Page" asp-action="CreatePage">
        <div class="form-group">
            <label>Moduller</label>
            <select class="form-select" name="ModuleIds">
                <option value="0" selected>Open this select menu</option>
                <option value="1">One</option>
                <option value="2">Two</option>
                <option value="3">Three</option>
            </select>
        </div>

        <div class="form-group">
            <label>Resim1</label>
            <input type="text" name="Image1" class="form-control" />
        </div>
        <div class="form-group">
            <label>Resim2</label>
            <input type="text" name="Image2" class="form-control" />
        </div>
        <div class="form-group">
            <label>Resim3</label>
            <input type="text" name="Image3" class="form-control" />
        </div>

        <div class="form-group">
            <label>Sıra</label>
            <input type="number" name="Order" class="form-control" />
        </div>

        <ul class="nav nav-tabs" id="myTab" role="tablist">
            @foreach (var lang in Model.Translations)
            {
                <li class="nav-item" role="presentation">
                    <button class="nav-link @(lang.Locale == "tr" ? "active" : "")" id="@lang.Locale-tab" data-bs-toggle="tab" data-bs-target="#@lang.Locale" type="button" role="tab" aria-controls="@lang.Locale" aria-selected="@(lang.Locale == "tr" ? "true" : "false")">
                        <img width="15" height="15" src="~/icons/@(lang.Locale).svg" />@lang.Locale
                    </button>
                </li>
            }
        </ul>

        <div class="tab-content mt-3" id="myTabContent">
            @for (int i = 0; i < Model.Translations.Count; i++)
            {
                var lang = Model.Translations.ToList()[i];
                <div class="tab-pane fade show @(lang.Locale == "tr" ? "active" : "")" id="@lang.Locale" role="tabpanel" aria-labelledby="@lang.Locale-tab">
                    <div class="card-body">
                        <input type="hidden" name="Translations[@i].Locale" value="@lang.Locale" />

                        <div class="form-group">
                            <label for="Title">Başlık</label>
                            <input type="text" name="Translations[@i].Title" class="form-control" value="@lang.Title" />
                        </div>
                        <div class="form-group">
                            <label for="Url">Url</label>
                            <input type="text" name="Translations[@i].Url" class="form-control" value="@lang.Url" />
                        </div>
                        <div class="form-group">
                            <label for="PageTitle">Sayfa Başlık</label>
                            <input type="text" name="Translations[@i].PageTitle" class="form-control" value="@lang.PageTitle" />
                        </div>
                        <div class="form-group">
                            <label for="Brief">Kısa Açıklama</label>
                            <input type="text" name="Translations[@i].Brief" class="form-control" value="@lang.Brief" />
                        </div>
                        <div class="form-group">
                            <label for="MetaDescription">Meta Açıklama</label>
                            <input type="text" name="Translations[@i].MetaDescription" class="form-control" value="@lang.MetaDescription" />
                        </div>
                        <div class="form-group">
                            <label for="Content">Açıklama</label>
                            <textarea class="form-control" name="Translations[@i].Content">@lang.Content</textarea>
                        </div>
                    </div>
                </div>
            }
        </div>

        <button class="btn btn-outline-primary">Kaydet</button>
    </form>


</div>