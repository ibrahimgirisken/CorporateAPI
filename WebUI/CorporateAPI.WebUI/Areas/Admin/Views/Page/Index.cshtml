@model List<CorporateAPI.WebUI.DTOs.Page.GetPageDTO>

@{
    ViewData["Title"] = "Hakkımızda Sayfası";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<table class="table table-hover">
    <tr>
        <th>#</th>
        <th>Başlık</th>
        <th>Çocuk Sayfalar</th>
        <th></th>
    </tr>
    @foreach (var item in Model)
    {
        <tr>
            <th>@item.Id</th>
            <td>@item.Translations.FirstOrDefault(t => t.Locale == "tr")?.Title ?? "Başlık Yok"</td>
            <td>@item.Children?.Count ?? 0</td>
            <td>
                <a asp-action="Delete" asp-controller="About" asp-route-id="@item.Id" class="btn btn-outline-danger">Sil</a>
                <a asp-action="Update" asp-controller="About" asp-route-id="@item.Id" class="btn btn-outline-info">Güncelle</a>
            </td>
        </tr>
    }
</table>
<br />
<a asp-action="CreatePage" asp-controller="Page" asp-area="Admin" class="btn btn-outline-primary">Yeni Sayfa Ekle</a>