@model UpdatePageViewModel
@{
    ViewData["Title"] = "Yeni Sayfa Ekleme";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="container-fluid my-5">
    <form method="post" asp-action="UpdatePage">
        <div class="form-group">
            <label asp-for="UpdatePageDTO.ModuleIds"></label>
            <select class="form-select" asp-for="UpdatePageDTO.ModuleIds">
                <option value=null selected=GetModuleDTOs>Seç</option>
                @foreach (var item in Model.GetModuleDTOs)
                {
                    <option value="@item.Id">
                        @item.ContentType
                    </option>
                }
            </select>
        </div>
        <div class="form-group">
            <input type="hidden" asp-for="UpdatePageDTO.Id"/>
            <label asp-for="UpdatePageDTO.Image1"></label>
            <input asp-for="UpdatePageDTO.Image1" class="form-control" />
            <label asp-for="UpdatePageDTO.Image2"></label>
            <input asp-for="UpdatePageDTO.Image2" class="form-control" />
            <label asp-for="UpdatePageDTO.Image3"></label>
            <input asp-for="UpdatePageDTO.Image3" class="form-control" />
        </div>
        <ul class="nav nav-tabs" id="myTab" role="tablist">
            @for (int i = 0; i < Model.GetLangDTOs.Count; i++)
            {
                var lang = Model.GetLangDTOs[i];
                <li class="nav-item" role="presentation">
                    <button class="nav-link @(lang.LangCode == "tr" ? "active" : "")" id="@lang.LangCode-tab" data-bs-toggle="tab" data-bs-target="#@lang.LangCode" type="button" role="tab" aria-controls="@lang.LangCode" aria-selected="@(lang.LangCode == "tr" ? "true" : "false")">
                        <img width="15" height="15" src="~/icons/@(lang.LangCode).svg" />@lang.LangCode
                    </button>
                </li>
            }
        </ul>
        <div class="tab-content mt-3" id="myTabContent">
            @for (int i = 0; i < Model.UpdatePageDTO.PageTranslations.Count; i++)
            {
                var translation = Model.UpdatePageDTO.PageTranslations[i];
                <div class="tab-pane fade show @(translation.Locale == "tr" ? "active" : "")" id="@translation.Locale" role="tabpanel" aria-labelledby="@translation.Locale-tab">
                    <div class="form-group">
                        <input type="hidden" asp-for="UpdatePageDTO.PageTranslations[i].Locale" />
                        <label asp-for="UpdatePageDTO.PageTranslations[i].Title"></label>
                        <input asp-for="UpdatePageDTO.PageTranslations[i].Title" class="form-control" />
                        <label asp-for="UpdatePageDTO.PageTranslations[i].Url"></label>
                        <input asp-for="UpdatePageDTO.PageTranslations[i].Url" class="form-control" />
                        <label asp-for="UpdatePageDTO.PageTranslations[i].PageTitle"></label>
                        <input asp-for="UpdatePageDTO.PageTranslations[i].PageTitle" class="form-control" />
                        <label asp-for="UpdatePageDTO.PageTranslations[i].Brief"></label>
                        <input asp-for="UpdatePageDTO.PageTranslations[i].Brief" class="form-control" />
                        <label asp-for="UpdatePageDTO.PageTranslations[i].MetaDescription"></label>
                        <input asp-for="UpdatePageDTO.PageTranslations[i].MetaDescription" class="form-control" />
                        <label asp-for="UpdatePageDTO.PageTranslations[i].Content"></label>
                        <textarea asp-for="UpdatePageDTO.PageTranslations[i].Content" class="form-control"></textarea>
                    </div>
                </div>
            }
        </div>
        <div class="form-check">
            <label asp-for="UpdatePageDTO.Status" class="form-check-label"></label>
            <input asp-for="UpdatePageDTO.Status" class="form-check-input" type="checkbox" />
        </div>
        <div class="form-group">
            <label asp-for="UpdatePageDTO.Order"></label>
            <input asp-for="UpdatePageDTO.Order" class="form-control" />
            <input type="submit" class="btn btn-primary" value="Kaydet" />
    </form>
</div>
