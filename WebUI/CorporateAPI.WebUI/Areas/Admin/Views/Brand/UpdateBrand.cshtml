@model UpdateBrandViewModel
@{
    ViewData["Title"] = "Marka Güncelleme Sayfası";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="container-fluid my-5">
    <form method="post" asp-action="UpdateBrand">
        <div class="form-group">
            <input type="hidden" asp-for="UpdateBrandDTO.Id" />
            <label asp-for="UpdateBrandDTO.Name"></label>
            <input asp-for="UpdateBrandDTO.Name" class="form-control" />
            <label asp-for="UpdateBrandDTO.Code"></label>
            <input asp-for="UpdateBrandDTO.Code" class="form-control" />
        </div>
        <div class="form-group">
            <label asp-for="UpdateBrandDTO.Order"></label>
            <input asp-for="UpdateBrandDTO.Order" class="form-control" />
            </div>
        <div class="form-check">
            <label asp-for="UpdateBrandDTO.Status" class="form-check-label"></label>
            <input asp-for="UpdateBrandDTO.Status" class="form-check-input" type="checkbox" />
        </div>
            <input type="submit" class="btn btn-primary" value="Kaydet" />
    </form>
</div>