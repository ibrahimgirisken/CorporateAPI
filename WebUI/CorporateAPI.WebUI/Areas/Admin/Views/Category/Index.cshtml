@model List<ResultCategoryDTO>

@{
    ViewData["Title"] = "Ürün Kategorileri";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<table class="table table-hover">
    <tr>
        <th>#</th>
        <th>Başlık</th>
        <th>Çocuk Sayfalar</th>
        <th></th>
    </tr>
    @foreach (var item in Model)
    {
        <tr>
            <th>@item.Id</th>
            <td>@item.CategoryTranslations.FirstOrDefault(t => t.Locale == "tr")?.Title</td>
            <td>@item.Order</td>
            <td>
                <a asp-action="DeleteCategory" asp-controller="Category" asp-route-id="@item.Id" class="btn btn-outline-danger">Sil</a>
                <a asp-action="UpdateCategory" asp-controller="Category" asp-route-id="@item.Id" class="btn btn-outline-info">Güncelle</a>
            </td>
        </tr>
    }
</table>
<br />
<a asp-action="CreateCategory" asp-controller="Category" asp-area="Admin" class="btn btn-outline-primary">Yeni Kategori Ekle</a>