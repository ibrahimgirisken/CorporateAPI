@model List<ResultModuleDTO>

@{
    ViewData["Title"] = "Moduller";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<table class="table table-hover">
    <tr>
        <th>#</th>
        <th>Başlık</th>
        <th>Sıra</th>
        <th></th>
    </tr>
    @foreach (var item in Model)
    {
        <tr>
            <th>@item.Id</th>
            <td>@item.ContentType</td>
            <td>@item.Order</td>
            <td>
                <a asp-action="DeleteModule" asp-controller="Module" asp-route-id="@item.Id" class="btn btn-outline-danger">Sil</a>
                <a asp-action="UpdateModule" asp-controller="Module" asp-route-id="@item.Id" class="btn btn-outline-info">Güncelle</a>
            </td>
        </tr>
    }
</table>
<br />
<a asp-action="CreateModule" asp-controller="Module" asp-area="Admin" class="btn btn-outline-primary">Yeni Modul Ekle</a>